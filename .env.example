# -----------------------------------------------------------------------------
# Sahnebul — örnek ortam değişkenleri
# Kopyala: cp .env.example .env && php artisan key:generate
# -----------------------------------------------------------------------------
APP_NAME=Sahnebul
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Istanbul

# --- Production önerisi (canlı .env) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://ornek.com
# LOG_CHANNEL=daily
# LOG_LEVEL=error
# SESSION_DRIVER=redis
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# BROADCAST_CONNECTION=log
# FILESYSTEM_DISK=s3

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Kritik hatalarda Slack (isteğe bağlı)
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_USERNAME="${APP_NAME}"

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sahnebul
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Forge / CDN arkasında doğru şema ve IP (ör. *) — boş bırakılırsa Laravel varsayılanı
TRUSTED_PROXIES=

# Laravel Forge deploy script: yalnızca ilk veri yüklemesi için 1 yapın, sonra silin.
# FORGE_DB_SEED=1

# JSON / harici API koruması (IP başına dakika)
RATE_LIMIT_REVERSE_GEOCODE=24
RATE_LIMIT_SEARCH_QUICK=60
RATE_LIMIT_EVENTS_NEARBY=45
RATE_LIMIT_API_LOCATIONS=90

# Google Maps (tarayıcı): Mekan formu — Places otomatik tamamlama.
# İsteğe bağlı: Admin → Ayarlar (süper yönetici) ile de kaydedilebilir; paneldeki değer .env’den önceliklidir.
GOOGLE_MAPS_API_KEY=

# Google Custom Search — php artisan artists:fetch-images-google
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Spotify Web API (isteğe bağlı)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=TR
SPOTIFY_LOCALE=tr_TR
# 0 = seed sonrası Spotify içe aktarmayı atla (CI/tünel önerilir). Yerelde 400 vb.
SPOTIFY_IMPORT_MAX=0
# db:seed sonrası artists:fetch-images (yavaş / ağır). true sadece yerel ihtiyaçta.
# NOT: Git push veritabanını ve storage/app/public dosyalarını taşımaz. Canlı = yerel içerik için
# mysqldump/import veya aynı seed + isteğe bağlı: php artisan artists:fetch-images
SEED_FETCH_ARTIST_IMAGES=false
SPOTIFY_IMPORT_MAX_CATEGORIES=30
SPOTIFY_IMPORT_PLAYLISTS_PER_CATEGORY=5
SPOTIFY_IMPORT_PLAYLIST_PAGES=4

MUSICBRAINZ_USER_AGENT="Sahnebul/1.0 (https://example.com)"
MUSICBRAINZ_MIN_INTERVAL=1.1
MUSICBRAINZ_SEARCH_QUERY=country:TR

WIKIDATA_USER_AGENT="Sahnebul/1.0 (https://example.com)"

# Türkiye API (şehir senkronu)
TURKIYE_API_BASE_URL=https://api.turkiyeapi.dev/v1
TURKIYE_API_DOCS_URL=https://docs.turkiyeapi.dev/

# Nominatim — ters jeodezik; politikaya uygun User-Agent zorunlu
NOMINATIM_USER_AGENT="Sahnebul/1.0 (https://example.com; you@example.com)"

# İsteğe bağlı: Instagram tanıtım videolarını sunucuya indirmek için yt-dlp (SaveFrom benzeri, kendi altyapınız)
# YTDLP_BINARY boşsa uygulama PATH, ~/.local/bin (posix ev dizini), /usr/bin, snap vb. içinde arar (PHP-FPM’de PATH boş olabilir).
# Linux: sudo apt install yt-dlp → genelde /usr/bin/yt-dlp | pipx install yt-dlp
# macOS: brew install yt-dlp → which yt-dlp
# YTDLP_BINARY=/usr/bin/yt-dlp
# pipx (Forge): YTDLP_BINARY=/home/forge/.local/bin/yt-dlp
# veya PATH’e ek dizin: YTDLP_EXTRA_PATHS=/home/forge/.local/bin
# Tilde: YTDLP_BINARY=~/.local/bin/yt-dlp
# YTDLP_TIMEOUT=300
# Giriş gerektiren içerikler için tarayıcıdan dışa aktarılan cookies.txt (hikâye /stories/… bağlantılarında sıkça zorunlu):
# YTDLP_COOKIES_FILE=/path/to/cookies.txt
# Okunabilir .env yolu panel yüklemesinden önceliklidir. Alternatif: süper admin → «Instagram çerez (video)» menüsünden Netscape cookies.txt yükleyin (SSH gerekmez).
# Aynı dosya, INSTAGRAM_FETCH_COOKIES boşken Laravel’in hikâye sayfası GET isteğine de uygulanır (tek dosya yeter).
# İsteğe bağlı: yt-dlp ek argümanları (JSON dizi — her öğe ayrı argv)
# YTDLP_EXTRA_ARGS_JSON='["--extractor-args","instagram:webpage_download_timeout=90"]'
# Galeride embed kaldıysa MP4’ü tekrar denemek: php artisan sahnebul:retry-instagram-promo-videos --dry-run
# Tek etkinlik: php artisan sahnebul:retry-instagram-promo-videos --event=123
#
# İsteğe bağlı: Kendi Cobalt sunucunuz (imputnet/cobalt, Docker). Instagram videoda çoğu durumda tarayıcı çerezi gerekmez.
# Üretimde kendi örneğinizi kullanın; api.cobalt.tools üçüncü parti otomasyon için uygun değildir.
# COBALT_API_URL=https://cobalt.ornek.com
# COBALT_API_KEY=
# COBALT_API_TIMEOUT=180
# true: önce Cobalt, sonra yt-dlp dene
# INSTAGRAM_TRY_COBALT_FIRST=false
#
# Laravel’in Instagram sayfasına doğrudan HTTP GET atması (og:image vb.): Netscape dosyasından öncelikli değil; istenirse ham satır:
# INSTAGRAM_FETCH_COOKIES="sessionid=...; csrftoken=...; ds_user_id=..."
# Çoklu Instagram URL içe aktarımında ardışık istekler arası bekleme (saniye). Varsayılan 0; sunucuda 429 olursa 4–8 verin:
# INSTAGRAM_BATCH_DELAY_SECONDS=6
# Aynı Instagram URL için HTML’den çıkan mp4 adaylarını kısa süre önbellekle (saniye; 0=kapalı TTL)
# INSTAGRAM_PROMO_CANDIDATE_CACHE_ENABLED=true
# INSTAGRAM_PROMO_CANDIDATE_CACHE_TTL=600
# Headless fallback: cd scripts/instagram-puppeteer-fetch && npm install
# INSTAGRAM_PUPPETEER_ENABLED=false
# INSTAGRAM_PUPPETEER_NODE=node
# INSTAGRAM_PUPPETEER_SCRIPT=
# INSTAGRAM_PUPPETEER_TIMEOUT=120
# Admin çoklu URL işlemi için PHP max_execution_time tavanı (Nginx fastcgi_read_timeout ile uyumlu tutun):
# PROMO_URL_IMPORT_TIME_LIMIT=900
#
# Instagram DASH video + ses (m4a) birleştirmek için ffmpeg (yt-dlp tek başına yeterli olmayabilir)
# macOS: brew install ffmpeg | Linux: apt install ffmpeg
# FFMPEG_BINARY boşsa /opt/homebrew/bin/ffmpeg, /usr/local/bin/ffmpeg, /usr/bin/ffmpeg ve PATH denenir.
# FFMPEG_BINARY=/usr/bin/ffmpeg
# FFMPEG_TIMEOUT=180

# --- Harici etkinlik crawl (Bubilet Cloudflare engeli için deneysel) ---
# Yalnızca _ga/_fbp yetmez; tarayıcıda sayfa yüklendikten sonra cf_clearance (ve çoğu zaman __cf_bm) gerekir.
# BUBILET_COOKIES="cf_clearance=...; __cf_bm=..."
# Netscape/curl cookies.txt (mutlak yol); panel yüklemesi yoksa okunur. BUBILET_COOKIES satırı aynı isimleri ezer.
# BUBILET_COOKIES_FILE=/path/to/bubilet-cookies.txt
# Alternatif (SSH gerekmez): Yönetici → «Bubilet çerez (crawl)» — storage/app/private/bubilet_crawler_cookies.txt
# BUBILET_USER_AGENT=
# BUBILET_REFERER=https://www.bubilet.com.tr/
# Bubilet etiket URL şehir segmenti (istanbul, ankara, …). Adminde şehir seçilmezse kullanılır.
# BUBILET_DEFAULT_CITY_SLUG=istanbul
# CRAWLER_MAX_EXECUTION_SECONDS=300
